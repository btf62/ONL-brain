# Copy this file to `.env` and fill in real local values.
# Never commit `.env` or real credentials.

# General
OPENAI_API_KEY=
ATLASSIAN_CLOUD_ID=

# Todoist
TODOIST_API_TOKEN=

# Online analytics reporting
ONLINE_ANALYTICS_REPORT_RECIPIENT=Jenny Miller <jmiller@northridgerochester.com>

# Church Online Platform
# Use manual admin analytics until a supported reporting API is confirmed.
CHURCH_ONLINE_ADMIN_URL=

# Resi
# Create a dedicated API client in Resi Studio for this repo's analytics work.
# Suggested client name: ONL Analytics Reporting - Read Only
# Tested role: Resi On Demand API
# Public API access is confirmed for On Demand metadata, not analytics.
RESI_API_CLIENT_NAME="ONL Analytics Reporting - Read Only"
RESI_API_CLIENT_ROLES=Resi On Demand API
RESI_API_BASE_URL=https://api.resi.io
RESI_STUDIO_URL=https://studio.resi.io
RESI_OAUTH_TOKEN_URL=https://api.resi.io/v1/oauth/token
RESI_OAUTH_SCOPE=
RESI_CLIENT_ID=
RESI_CLIENT_SECRET=

# YouTube Analytics
# Use read-only OAuth scopes only.
YOUTUBE_CHANNEL_ID=
YOUTUBE_ANALYTICS_SCOPE=https://www.googleapis.com/auth/yt-analytics.readonly
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Facebook / Meta
# Use only approved Page analytics reads after metric definitions are confirmed.
META_PAGE_ID=
META_ACCESS_TOKEN=

# App and TV analytics
# Fill in after the canonical source for mobile app, Apple TV, and Roku metrics is known.
APP_TV_ANALYTICS_SOURCE=

# System
LOG_TIME_ZONE=America/New_York
